# Без Docker (npm run dev): http://localhost:4000/api
# С Docker (HTTPS): https://ваш-домен/api или относительный /api
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# TURN для звонков (если ICE failed, звука нет). См. docs/TURN-setup.md
# NEXT_PUBLIC_TURN_SERVER=turn:IP_СЕРВЕРА:3478
# NEXT_PUBLIC_TURN_USERNAME=messenger
# NEXT_PUBLIC_TURN_CREDENTIAL=твой-пароль
